<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Needed to keep a session alive while both apps are backgrounded — same reasoning as the
         Linux Plugin's LinuxSessionService.startForeground. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="LobiShell Remote Desktop Plugin"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".InfoActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- exported="true" for cross-app binding; no custom Android permission gates it — see
             RemoteDesktopSessionService.onBind's doc for why (a "dangerous" custom permission's
             grant dialog renders as a generic "perform an unknown action" on modern Android). -->
        <service
            android:name=".RemoteDesktopSessionService"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps a user-started remote desktop session (VNC/RDP/SPICE) alive while backgrounded" />
            <intent-filter>
                <action android:name="de.lobianco.saftssh.remotedesktop.BIND_SESSION_SERVICE" />
            </intent-filter>
        </service>

    </application>

</manifest>
